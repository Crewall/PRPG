{
  "name": "prpg",
  "version": "0.1.0",
  "private": true,
  "description": "PRPG — AI-Orchestrated Roleplay Engine",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node --experimental-sqlite src/index.ts",
    "dev": "node --experimental-sqlite --watch src/index.ts",
    "smoke": "node --experimental-sqlite scripts/smoke.ts",
    "migrate": "node --experimental-sqlite scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
